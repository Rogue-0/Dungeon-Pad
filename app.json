{
  "expo": {
    "name": "Dungeon Pad",
    "slug": "dungeon-pad",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "scheme": "dungeon-pad",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF9F7"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
